# ── Google OAuth2 (Gmail + Sheets) ──────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
# Run `npm run auth` once to generate these tokens
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# ── Gmail ────────────────────────────────────────────────────────────────────
# The inbox that customers send damage claims to
CLAIMS_EMAIL=claims@cavari.com
# How often to check for new claim emails (milliseconds). Default: 2 minutes
GMAIL_POLL_INTERVAL=120000

# ── Google Sheets ────────────────────────────────────────────────────────────
# Create a Google Sheet, share it with the OAuth account, copy the ID from the URL
# URL format: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_admin_api_token

# ── Anthropic (Claude Vision) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── FedEx ────────────────────────────────────────────────────────────────────
# Your FedEx account credentials for the claims portal
FEDEX_PORTAL_EMAIL=your_fedex_login_email
FEDEX_PORTAL_PASSWORD=your_fedex_login_password
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number
# Cavari contact details used when filing carrier claims
CAVARI_COMPANY_NAME=Cavari
CAVARI_CONTACT_NAME=Your Name
CAVARI_CONTACT_EMAIL=ops@cavari.com
CAVARI_CONTACT_PHONE=+1-000-000-0000
CAVARI_ADDRESS=123 Main St, City, State, ZIP

# ── Claim rules ───────────────────────────────────────────────────────────────
# Max hours after confirmed delivery to accept a claim
CLAIM_WINDOW_HOURS=72
# Order value (USD) below which claims are auto-approved if no hard blocks
AUTO_APPROVE_THRESHOLD=300

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
