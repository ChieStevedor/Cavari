# ── Supabase (public / browser-safe) ──────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Phase 2: Klaviyo (set this in Vercel env to activate) ────────────────────
# Also set KLAVIYO_API_KEY (no VITE_ prefix) in Vercel for the server route.
# Setting VITE_KLAVIYO_API_KEY enables the Sync button in the UI.
VITE_KLAVIYO_API_KEY=
KLAVIYO_API_KEY=

# ── Phase 3: Project Tracker (set these in Vercel env to activate) ──────────
# Set VITE_PROJECT_TRACKER_ENABLED=true once the server route is configured.
VITE_PROJECT_TRACKER_ENABLED=false
PROJECT_TRACKER_SUPABASE_URL=
PROJECT_TRACKER_SERVICE_KEY=
TOTAL_PORTFOLIO_BRANDS=12

# ── Resend (server-side only — set in Vercel, not here) ──────────────────────
RESEND_API_KEY=re_...
DIGEST_RECIPIENT=alex@cavari.design

# ── Cron security ─────────────────────────────────────────────────────────────
CRON_SECRET=generate-a-long-random-string

# ── Supabase server-side (for cron route) ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
